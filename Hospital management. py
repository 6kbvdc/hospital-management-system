# --- Appointment Functions ---
def schedule_appointment():
    view_patients()
    pid = get_valid_id("Select Patient ID: ")
    view_staff()
    sid = get_valid_id("Select Staff ID: ")
    date = get_valid_date("Date (YYYY-MM-DD): ")
    time = get_valid_time("Time (HH:MM): ")
    c.execute("INSERT INTO appointments (patient_id, staff_id, date, time) VALUES (?, ?, ?, ?)",
              (pid, sid, date, time))
    conn.commit()
    aid = c.lastrowid
    log_action("ADD", "appointments", aid)
    print("Appointment scheduled successfully.\n")

def view_appointments():
    date_filter = input("Filter by date (YYYY-MM-DD) or leave blank: ").strip()
    query = '''
        SELECT a.id, p.name, s.name, a.date, a.time
        FROM appointments a
        JOIN patients p ON a.patient_id = p.id
        JOIN staff s ON a.staff_id = s.id
    '''
    if date_filter:
        query += " WHERE a.date=?"
        c.execute(query, (date_filter,))
    else:
        c.execute(query)
    rows = c.fetchall()
    if rows:
        for row in rows:
            print(row)
    else:
        print("No appointments found.")
    print()

def cancel_appointment():
    aid = get_valid_id("Enter Appointment ID to cancel: ")
    c.execute("SELECT * FROM appointments WHERE id=?", (aid,))
    if not c.fetchone():
        print("Appointment not found.\n")
        return
    c.execute("DELETE FROM appointments WHERE id=?", (aid,))
    conn.commit()
    log_action("DELETE", "appointments", aid)
    print("Appointment canceled successfully.\n")

# --- Commit History Function ---
def view_history():
    c.execute("SELECT * FROM history ORDER BY timestamp DESC")
    rows = c.fetchall()
    if rows:
        for row in rows:
            print(row)
    else:
        print("No history found.")
    print()

# --- Main Menu ---
def main_menu():
    while True:
        print("=== Hospital Management System ===")
        print("1. Add Patient      2. View Patients      3. Update Patient      4. Delete Patient")
        print("5. Add Staff        6. View Staff         7. Update Staff        8. Delete Staff")
        print("9. Schedule Appointment   10. View Appointments   11. Cancel Appointment")
        print("12. View Commit History   13. Exit")
        choice = input("Enter choice: ")

        if choice == '1':
            add_patient()
        elif choice == '2':
            view_patients()
        elif choice == '3':
            update_patient()
        elif choice == '4':
            delete_patient()
        elif choice == '5':
            add_staff()
        elif choice == '6':
            view_staff()
        elif choice == '7':
            update_staff()
        elif choice == '8':
            delete_staff()
        elif choice == '9':
            schedule_appointment()
        elif choice == '10':
            view_appointments()
        elif choice == '11':
            cancel_appointment()
        elif choice == '12':
            view_history()
        elif choice == '13':
            print("Exiting system.")
            break
        else:
            print("Invalid choice.\n")

if __name__ == "__main__":
    main_menu()
    conn.close()
    
